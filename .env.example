# ── Base PostgreSQL (obligatoire) ──────────────────────────────────────────
# Local  : docker compose up -d
# Render : copier Internal Database URL (ajouter ?sslmode=require si absent)
DATABASE_URL="postgresql://mega:mega_secret@localhost:5432/mega_finance"
# DATABASE_SSL="true"

# ── Auth JWT (obligatoire, min. 16 caractères) ─────────────────────────────
AUTH_SECRET="changez-moi-en-production-min-16-car"

# ── Comptes seed (npm run db:seed-users ou db:seed) ────────────────────────
ADMIN_IDENTIFIANT="admin"
ADMIN_PASSWORD="Admin@2026"
CEO_PASSWORD="Ceo@2026"

# ── URL publique (Render / domaine custom) ─────────────────────────────────
# NEXT_PUBLIC_APP_URL="https://mega-admin.onrender.com"
# ou "https://admin.mega-sn.com"

# ── Archives pièces (optionnel — Persistent Disk Render) ───────────────────
# ARCHIVES_DIR="/var/data/archives"

# ── Google OAuth (optionnel) ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# GOOGLE_ALLOWED_DOMAIN="mega-sn.com"
# Redirect URI : {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
