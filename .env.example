# ── Base PostgreSQL (obligatoire) ──────────────────────────────────────────
# Local (Homebrew) : postgresql://postgres:postgres@localhost:5432/mega_db
# Local (Docker)   : postgresql://mega:mega_secret@localhost:5432/mega_finance
# Vercel           : Neon / Supabase / Vercel Postgres (+ ?sslmode=require)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mega_db"
# DATABASE_SSL="true"

# ── Auth JWT (obligatoire, min. 16 caractères) ─────────────────────────────
AUTH_SECRET="changez-moi-en-production-min-16-car"

# ── Comptes seed (npm run db:seed-users ou db:seed) ────────────────────────
ADMIN_IDENTIFIANT="admin"
ADMIN_PASSWORD="Admin@2026"
CEO_PASSWORD="Ceo@2026"

# ── URL publique (Vercel / domaine custom) ─────────────────────────────────
# NEXT_PUBLIC_APP_URL="https://votre-projet.vercel.app"
# NEXT_PUBLIC_APP_URL="https://admin.mega-sn.com"

# ── Archives pièces (éphémère sur Vercel sans stockage objet) ──────────────
# ARCHIVES_DIR="./data/archives"

# ── Google OAuth (optionnel) ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# GOOGLE_ALLOWED_DOMAIN="mega-sn.com"
# Redirect URI : {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
