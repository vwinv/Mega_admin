# ─── Base de données ───────────────────────────────────────────────
# PostgreSQL (par défaut)
# Démarrer : docker compose up -d
DATABASE_URL="postgresql://mega:mega_secret@localhost:5432/mega_finance"

# ─── Authentification ──────────────────────────────────────────────
AUTH_SECRET="mega-sn-dev-secret-changez-moi-en-prod"
ADMIN_IDENTIFIANT="admin"
ADMIN_PASSWORD="Admin@2026"
CEO_PASSWORD="Ceo@2026"

# Connexion Google (Google Cloud Console → Identifiants OAuth 2.0)
# URI de redirection autorisée : http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Optionnel : domaine autorisé (ex. mega-sn.com)
# GOOGLE_ALLOWED_DOMAIN="mega-sn.com"
# URL publique de l'app (production)
# NEXT_PUBLIC_APP_URL="https://votre-domaine.com"

# ─── Application ─────────────────────────────────────────────────
NODE_ENV=development
