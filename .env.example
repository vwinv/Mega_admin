# Base PostgreSQL (obligatoire en production / Vercel)
# Ex. Neon, Supabase, Vercel Postgres, ou docker compose up -d
DATABASE_URL="postgresql://user:password@host:5432/mega_db"

# Secret session JWT (générer une valeur longue et aléatoire en prod)
AUTH_SECRET="changez-moi-en-production"

# Comptes initiaux (utilisés par le seed)
ADMIN_IDENTIFIANT="admin"
ADMIN_PASSWORD="Admin@2026"
CEO_PASSWORD="Ceo@2026"

# Connexion Google (optionnel)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# GOOGLE_ALLOWED_DOMAIN="mega-sn.com"

# URL publique de l'app (obligatoire en prod pour OAuth Google)
# NEXT_PUBLIC_APP_URL="https://votre-app.vercel.app"
