{
  "name": "mega-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "local:start": "bash scripts/dev-server.sh start",
    "local:stop": "bash scripts/dev-server.sh stop",
    "local:restart": "bash scripts/dev-server.sh restart",
    "local:status": "bash scripts/dev-server.sh status",
    "local:watch": "bash scripts/dev-server.sh watch",
    "local:logs": "bash scripts/dev-server.sh logs",
    "build": "next build --webpack",
    "vercel-build": "prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:setup": "prisma migrate deploy && prisma db seed",
    "db:reset": "prisma migrate reset --force",
    "db:status": "npx tsx scripts/db-status.ts",
    "db:backup": "npx tsx scripts/db-backup.ts",
    "db:seed-users": "npx tsx scripts/seed-users-only.ts",
    "db:reset-passwords": "npx tsx scripts/reset-seed-passwords.ts",
    "db:backfill-pieces": "npx tsx scripts/backfill-numero-piece.ts --all",
    "db:fix-init-baseline": "prisma migrate resolve --rolled-back 20260707180000_init ; prisma migrate resolve --applied 20260707180000_init && prisma migrate deploy",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vercel/blob": "^2.6.1",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "optionalDependencies": {
    "@next/swc-darwin-arm64": "^16.2.10"
  }
}
